<script>
  const slider = document.querySelector(".slider");
  const prevBtn = document.querySelector(".prev");
  const nextBtn = document.querySelector(".next");

  let slideWidth = slider.querySelector(".slide").offsetWidth + 20;
  let autoScroll;

  function moveNext() {
    slider.style.transition = "transform 0.5s ease";
    slider.style.transform = `translateX(-${slideWidth}px)`;

    setTimeout(() => {
      slider.style.transition = "none";
      slider.appendChild(slider.firstElementChild);
      slider.style.transform = "translateX(0)";
    }, 500);
  }

  function movePrev() {
    slider.style.transition = "none";
    slider.prepend(slider.lastElementChild);
    slider.style.transform = `translateX(-${slideWidth}px)`;

    setTimeout(() => {
      slider.style.transition = "transform 0.5s ease";
      slider.style.transform = "translateX(0)";
    }, 10);
  }

  nextBtn.addEventListener("click", moveNext);
  prevBtn.addEventListener("click", movePrev);

  function startAuto() {
    autoScroll = setInterval(moveNext, 3000);
  }

  function stopAuto() {
    clearInterval(autoScroll);
  }

  slider.addEventListener("mouseenter", stopAuto);
  slider.addEventListener("mouseleave", startAuto);

  window.addEventListener("resize", () => {
    slideWidth = slider.querySelector(".slide").offsetWidth + 20;
  });

  startAuto();
</script>

<script>
  const track = document.querySelector(".carousel-track");
  const leftBtn = document.querySelector(".left-arrow");
  const rightBtn = document.querySelector(".right-arrow");

  let cardWidth = track.querySelector(".card-item").offsetWidth + 20;
  let autoSlide;

  function slideNext() {
    track.style.transition = "transform 0.5s ease";
    track.style.transform = `translateX(-${cardWidth}px)`;

    setTimeout(() => {
      track.style.transition = "none";
      track.appendChild(track.firstElementChild);
      track.style.transform = "translateX(0)";
    }, 500);
  }

  function slidePrev() {
    track.style.transition = "none";
    track.prepend(track.lastElementChild);
    track.style.transform = `translateX(-${cardWidth}px)`;

    setTimeout(() => {
      track.style.transition = "transform 0.5s ease";
      track.style.transform = "translateX(0)";
    }, 10);
  }

  rightBtn.addEventListener("click", slideNext);
  leftBtn.addEventListener("click", slidePrev);

  function startAuto() {
    autoSlide = setInterval(slideNext, 3000);
  }

  function stopAuto() {
    clearInterval(autoSlide);
  }

  track.addEventListener("mouseenter", stopAuto);
  track.addEventListener("mouseleave", startAuto);

  window.addEventListener("resize", () => {
    cardWidth = track.querySelector(".card-item").offsetWidth + 20;
  });

  startAuto();
</script>



<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
/* ===== Modal Open/Close ===== */
function openModal(){ document.getElementById("shopModal").style.display="block"; }
function closeModal(){ document.getElementById("shopModal").style.display="none"; }
function openMapModal(){ document.getElementById("mapModal").style.display="block"; initMap(); }
function closeMapModal(){ document.getElementById("mapModal").style.display="none"; }

/* ===== Leaflet Map ===== */
let map, marker;
function initMap() {
  if(map) return; // initialize once
  map = L.map('map').setView([17.3850, 78.4867], 12); // default Hyderabad
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OpenStreetMap contributors'
  }).addTo(map);

  map.on('click', function(e){
    if(marker) map.removeLayer(marker);
    marker = L.marker(e.latlng).addTo(map);
  });
}

function selectLocation() {
  if(!marker){ alert("Please select a point on the map!"); return; }
  const lat = marker.getLatLng().lat;
  const lng = marker.getLatLng().lng;
  document.getElementById("locationLink").value = `https://www.openstreetmap.org/?mlat=${lat}&mlon=${lng}#map=18/${lat}/${lng}`;
  closeMapModal();
}

/* ===== District → Area Dynamic ===== */
const districtAreas = {
  hyderabad: ["Nagole", "Tarnaka", "Dilsukhnagar", "LB Nagar", "Uppal", "Afzalgunj", "Koti", "Charminar"],
  rangareddy: ["Ibrahimpatnam", "B.N. Reddy Nagar", "Meerpet", "Balapur", "Cherlapalli", "Ghatkesar"]
};

document.getElementById("district").addEventListener("change", function() {
  const selectedDistrict = this.value;
  const areaSelect = document.getElementById("area");
  areaSelect.innerHTML = '<option value="">Select Area</option>';
  if(selectedDistrict && districtAreas[selectedDistrict]){
    districtAreas[selectedDistrict].forEach(area => {
      const opt = document.createElement("option");
      opt.value = area.toLowerCase();
      opt.textContent = area;
      areaSelect.appendChild(opt);
    });
  }
});
</script>


<script>
  const shopForm = document.getElementById('shopForm');

  shopForm.addEventListener('submit', async function(e){
    e.preventDefault(); // default submit roko

    const formData = new FormData(shopForm); // includes file + fields

    try {
      const response = await fetch('/shops/register', {
        method: 'POST',
        body: formData
      });

      const data = await response.json();

      if(response.ok){
        // ✅ Success alert with shop name
        alert(`Shop "${data.shop.name}" registered successfully!`);

        // ✅ Redirect to home page
        window.location.href = '/';
      } else {
        // Error from backend
        alert(data.message || "Something went wrong!");
      }

    } catch (err) {
      console.error(err);
      alert("Network or server error!");
    }
  });
</script>




