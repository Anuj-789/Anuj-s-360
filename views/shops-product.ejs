<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Anuj's-360</title>
  <link rel="stylesheet" href="../public/css/allstructure/nav.css">
  <link rel="stylesheet" href="../public/css/productbox.css">
    <link rel="stylesheet" href="../public/css/cartpage.css">
    <link rel="stylesheet" href="../public/css/favourate.css">
       <link rel="stylesheet" href="../public/css/shopdetails.css">
  <style>
    /* NAVBAR */
.navbar {
       border-bottom: 3px solid rgb(15, 12, 158);
     position: fixed;   /* navbar scroll par bhi upar rahega */
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    }

/* MAIN CONTAINER */


/* LEFT SHOP BOX */


  
        

button, a {
  -webkit-tap-highlight-color: transparent;  /* blue highlight remove karega */
}
      

  </style>
</head>
<body>



<!-- ===== NAVBAR (YOUR CODE) ===== -->
<nav class="navbar">
    
    <div class="nav-left">
       
        <img src="../public/images/logo.jpg" alt="Logo">
        
    </div>

    <div class="nav-center">
        <marquee direction="up" behavior="slide">your's shop </marquee>
    </div>

    <div class="nav-right"  onclick="openCart('<%= shop._id %>', '<%= shop.name %>')" style="cursor:pointer;">
       
        <img src="../public/images/cart.jpg" id="menuBtn">
        <!--<p >View Cart</p>-->
        <button >View Cart 🛒</button>

    </div>
</nav>

<!-- MAIN LAYOUT -->
<div class="main-container">

  <!-- LEFT SHOP BOX -->
<!-- LEFT SHOP BOX -->
<aside class="shop-box" id="shopBox">

  <img src="<%= shop.image %>" class="shop-img" alt="<%= shop.name %>">

  <h2 class="shop-name"><%= shop.name %></h2>

  <div class="shop-rating">
    ⭐⭐⭐⭐☆ (<%= shop.rating || 4.4 %>)
  </div>

  <div class="shop-time">
    🕘 <%= shop.timing || "9 AM – 10 PM" %>
  </div>

  <p class="shop-desc">
    <%= shop.description || "Best quality products at affordable prices." %>
  </p>

  <div class="shop-actions">
     <button class="nav-back" onclick="history.back()">⬅Back</button>
  </div>

</aside>




  <!-- RIGHT PRODUCTS -->
  <section class="product-area">
    <div class="product-grid">
      <!-- yahin saare product cards aayenge -->


  <% if (products.length === 0) { %>
    <p>No products available</p>
  <% } %>

  <% products.forEach(product => { %>

    <div class="product-card">
      <div class="image-box">
        <% if (product.offer) { %>
          <span class="offer-badge"><%= product.offer %>% OFF</span>
        <% } %>

        <img src="<%= product.image %>" alt="<%= product.name %>">
      </div>

      <div class="product-info">
        <h3 class="product-name"><%= product.name %></h3>
        <p class="product-desc"><%= product.description || "Best product" %></p>

        <div class="price-section">
          <span class="price">₹<%= product.price %></span>
          <% if (product.oldPrice) { %>
            <span class="old-price">₹<%= product.oldPrice %></span>
          <% } %>
        </div>

        <div class="rating">
          ⭐⭐⭐⭐☆ <span>(<%= product.rating || 4.2 %>)</span>
        </div>

        <div class="action-row">
       
         
          <button  class="cart-btn"
                   onclick="addToCart('<%= product._id %>', '<%= shop._id %>')" >  Add to Cart  </button>
         
        </div>
      </div>
    </div>

  <% }) %>



    </div>
  </section>



</div>


<div id="cartOverlay" class="cart-overlay" onclick="closeCart()"></div>

<div id="cartPanel" class="cart-panel">
  <div class="cart-header">
    
    <h3>Your Cart 🛒</h3>
  </div>

  <div id="cartContent">
    <p>Loading...</p>
  </div>
</div>



<div id="paymentOptionModal" style="
  display:none;
  position:fixed;
  top:0; left:0; width:100%; height:100%;
  background: rgba(0,0,0,0.6);
  justify-content:center;
  align-items:center;
  z-index:2000;
">
  <div style="
    background:white;
    padding:20px;
    border-radius:12px;
    width:280px;
    text-align:center;
    position:relative;
  ">
    <h2>Select Payment Method</h2>
    <div style="margin:20px 0;">
      <button id="payOnlineBtn" style="width:100%;padding:10px;margin-bottom:10px;background:green;color:white;border:none;border-radius:6px;">Pay Online</button>
      <button id="codBtn" style="width:100%;padding:10px;background:gray;color:white;border:none;border-radius:6px;">Cash on Delivery</button>
    </div>
    <button id="closePaymentOption" style="margin-top:10px;">Cancel</button>
  </div>
</div>


</body>

<script>
let lastScroll = 0;
const navbar = document.getElementById("navbar");
const shopBox = document.getElementById("shopBox");

window.addEventListener("scroll", () => {
  let currentScroll = window.pageYOffset;

  if (currentScroll > lastScroll) {
    // scrolling down
    navbar.classList.add("hide");
    shopBox.classList.add("hide-left");
  } else {
    // scrolling up
    navbar.classList.remove("hide");
    shopBox.classList.remove("hide-left");
  }

  lastScroll = currentScroll;
});
</script>



<script>
    const menuBtn = document.getElementById("menuBtn");
    const dropdownMenu = document.getElementById("dropdownMenu");
    const backBtn = document.querySelector(".menu-header");

    menuBtn.addEventListener("click", () => {
        dropdownMenu.classList.toggle("show");
    });

    backBtn.addEventListener("click", () => {
        dropdownMenu.classList.remove("show");
    });
</script>



<!-- Function to handle "Add to Cart" button click -->

<!-- Function for open cart panel with data-->
<script>
// OPEN / CLOSE CART PANEL
function openCart(shopId, shopName) {
  const panel = document.getElementById("cartPanel");
  panel.classList.add("show");
  document.getElementById("cartOverlay").classList.add("show");
  document.body.style.overflow = "hidden";
  loadCartData(shopId, shopName); // fetch latest cart from backend
}

function closeCart() {
  const panel = document.getElementById("cartPanel");
  panel.classList.remove("show");
  document.getElementById("cartOverlay").classList.remove("show");
  document.body.style.overflow = "auto";
}



function renderCart(cart, shopName) {
  const box = document.getElementById("cartContent");

  // 🔹 Check if cart is null/undefined
  if (!cart) {
    box.innerHTML = `<h4>${shopName || "Shop"}</h4><p>Error loading cart</p>`;
    return;
  }

  // 🔹 Check login requirement from backend
  if (cart.message === "Login required") {
    alert("Please login to view your cart!");
    window.location.href = "/profile";
    return;
  }

  // 🔹 Empty cart check
  if (!cart.items || cart.items.length === 0) {
    box.innerHTML = `<h4>${cart.shop?.name || shopName || "Shop"}</h4><p>Your cart is empty</p>`;
    return;
  }

  let html = `<h4>${cart.shop?.name || shopName || "Shop"}</h4>`;
  let total = 0;

  cart.items.forEach(item => {
    // safety: make sure item.product exists
    if (!item.product) return;

    const itemTotal = (item.product.price || 0) * (item.quantity || 1);
    total += itemTotal;

    html += `
      <div style="margin-bottom:12px; border-bottom:1px solid #ddd; padding-bottom:8px;">
        <strong>${item.product.name || "Unnamed Product"}</strong>
        <p>Price: ₹${item.product.price || 0}</p>
        <p>
          Quantity:
          <button onclick="updateQty('${item.product._id}', ${item.quantity - 1}, '${cart.shop._id}')">-</button>
          ${item.quantity}
          <button onclick="updateQty('${item.product._id}', ${item.quantity + 1}, '${cart.shop._id}')">+</button>
        </p>
        <p>Subtotal: ₹${itemTotal}</p>
      
        <button onclick="removeItem('${item.product._id}', '${cart.shop._id}', '${cart.shop?.name || shopName}')">Remove ❌</button>
      </div>
    `;
  });

  html += `<h3>Total: ₹${total}</h3>`;

  html += `<button class ="buynowbotton"
    style="width:100%;padding:12px;background:blue;color:white;border:none;border-radius:8px;margin-top:10px;"
    onclick="showPaymentOptions()">
    Buy Now 🛒
</button> `;



  box.innerHTML = html;
}


// LOAD CART DATA
function loadCartData(shopId, shopName) {
  fetch(`/cart/data?shopId=${shopId}`,{headers: { "Accept": "application/json" }})
    .then(res => res.json())
    .then(cart => {
      // 🔹 Login required check
      if (!cart || cart.message === "Login required") {
        alert("Please login to view your cart!");
        window.location.href = "/profile";
        return;
      }

      // 🔹 Ensure cart.items exists
      if (!cart.items) {
        cart.items = [];
      }

      renderCart(cart, shopName);
    })
    .catch(err => {
      console.error(err);
      alert("Something went wrong while loading cart");
    });
}

// ADD TO CART
function addToCart(productId, shopId) { 
  fetch("/cart/add", {
    method: "POST",
    headers: { 
      "Content-Type": "application/json", 
      "Accept": "application/json"
    },
    body: JSON.stringify({ productId, shopId })
  })
  .then(res => res.json().then(data => {
    if (!res.ok) throw data; // throw JSON from backend
    return data;
  }))
  .then(data => {
    // normal flow
    if (!data.shop) throw new Error("Cart data incomplete");

    alert(`Product added to ${data.shop.name} cart!`);

    const panel = document.getElementById("cartPanel");
    if (panel.classList.contains("show")) renderCart(data);
  })
  .catch(err => {
    console.error(err);

    // 🔹 Login required check
    if (err.message === "Login required" || err?.message === "Login required") {
      alert("Please login first!");
      window.location.href = "/profile"; // 🔹 redirect here
      return;
    }

    alert("Something went wrong: " + (err.message || err));
  });
}








// UPDATE QUANTITY
function updateQty(productId, newQty, shopId, shopName) {
  if (newQty < 1) return;

  fetch("/cart/update", {
    method: "POST",
    headers: { "Content-Type": "application/json" , "Accept": "application/json" },
    body: JSON.stringify({ productId, quantity: newQty, shopId })
  })
  .then(res => res.json())
  .then(data => {
    // 🔹 Check login status
    if (!data || data.message === "Login required") {
      alert("Please login first to update cart!");
      window.location.href = "/profile";
      return;
    }

    // 🔹 Load updated cart safely
    loadCartData(shopId, shopName || "this shop"); 
  })
  .catch(err => {
    console.error(err);
    alert("Something went wrong while updating cart");
  });
}


// REMOVE ITEM
function removeItem(productId, shopId, shopName) {
  fetch("/cart/remove", {
    method: "POST",
    headers: { "Content-Type": "application/json" , "Accept": "application/json" },
    body: JSON.stringify({ productId, shopId })
  })
  .then(res => res.json())
  .then(data => {
    // 🔹 Check login status
    if (!data || data.message === "Login required") {
      alert("Please login first to remove items from cart!");
      window.location.href = "/profile";
      return;
    }

    // 🔹 Render cart safely
    renderCart(data, shopName || "this shop"); 
  })
  .catch(err => {
    console.error(err);
    alert("Something went wrong while removing item");
  });
}

</script>

<script>
function showPaymentOptions() {
  const modal = document.getElementById("paymentOptionModal");
  modal.style.display = "flex";

  document.getElementById("payOnlineBtn").onclick = () => {
    modal.style.display = "none";
    payOnlineModal(); // Online payment modal function, next step me add karenge
  };

  document.getElementById("codBtn").onclick = () => {
    showOrderPlacedModal("Cash on Delivery");
  };

  document.getElementById("closePaymentOption").onclick = () => {
    modal.style.display = "none";
  };
}
</script>



<script>
function payOnlineModal() {
  const modal = document.createElement("div");
  modal.id = "payOnlineModal";
  modal.style.cssText = `
    position:fixed; top:0; left:0; width:100%; height:100%;
    background: rgba(0,0,0,0.6);
    display:flex; justify-content:center; align-items:center;
    z-index:3000;
  `;

  modal.innerHTML = `
    <div style="
      background:white;
      padding:20px;
      border-radius:12px;
      width:280px;
      text-align:center;
    ">
      <h2>Pay Online</h2>
      <div style="margin:20px 0; font-size:20px; font-weight:bold;">
        Amount: ₹<span id="payAmount">0</span>
      </div>
      <div style="margin-bottom:15px;">
        <img id="qrImage" src="/public/images/scanner.jpeg" alt="QR Code" style="width:200px; height:200px;"/>
      </div>
      <button id="donePayment" style="width:100%;padding:10px;background:green;color:white;border:none;border-radius:6px;margin-bottom:10px;">Done ✅</button>
      <button id="backPayment" style="width:100%;padding:10px;background:gray;color:white;border:none;border-radius:6px;">Back ⬅</button>
    </div>
  `;

  document.body.appendChild(modal);

  // Set payable amount from cart
  const totalElem = document.querySelector("#cartContent h3");
  const amount = totalElem ? totalElem.textContent.replace("Total: ₹", "") : "0";
  document.getElementById("payAmount").textContent = amount;

  document.getElementById("donePayment").onclick = () => {
   document.body.removeChild(modal); // close scanner
  showOrderPlacedModal("Online Payment 💳");
  };

  document.getElementById("backPayment").onclick = () => {
    document.body.removeChild(modal);
    showPaymentOptions();
  };
}



</script>


<script>
function showOrderPlacedModal(method = "COD") {
  const modal = document.createElement("div");
  modal.id = "orderPlacedModal";
  modal.style.cssText = `
    position:fixed; top:0; left:0; width:100%; height:100%;
    background: rgba(0,0,0,0.6);
    display:flex; justify-content:center; align-items:center;
    z-index:3000;
  `;

  modal.innerHTML = `
    <div style="
      background:white;
      padding:20px;
      border-radius:12px;
      width:280px;
      text-align:center;
    ">
      <h2>Order Placed 🎉</h2>
      <p style="font-size:16px; font-weight:bold; color:green;">
        Payment Method: ${method}
      </p>
      <p style="font-size:18px; font-weight:bold;">
        Total: ₹<span id="orderAmount">0</span>
      </p>
      <p style="margin:15px 0;">Your order has been placed successfully ✅</p>
      <p style="color:green; font-weight:bold;">Arrives in 30 minutes ⏱️</p>
      <button id="orderMore"
        style="width:100%;padding:10px;background:green;color:white;border:none;border-radius:6px;margin-top:15px;">
        Order More 🛒
      </button>
    </div>
  `;

  document.body.appendChild(modal);

  // Get total from cart
  const totalElem = document.querySelector("#cartContent h3");
  const amount = totalElem ? totalElem.textContent.replace("Total: ₹", "") : "0";
  document.getElementById("orderAmount").textContent = amount;

  const shopId = "<%= shop._id %>";
  const shopName = "<%= shop.name %>";

  // 🔥 POST request to backend
  fetch("/order/place", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      method,
      total: amount,
      shopId,
      shopName
    })
  })
  .then(res => res.json())
  .then(data => {
    console.log(data.message);

    // Update UI: Clear cart visually
    const cartList = document.querySelector("#cartContent ul");
    if(cartList) cartList.innerHTML = ""; // remove all items
    const totalDisplay = document.querySelector("#cartContent h3");
    if(totalDisplay) totalDisplay.textContent = "Total: ₹0";
  })
  .catch(err => console.error("Order flow error:", err));

  document.getElementById("orderMore").onclick = () => {
    document.body.removeChild(modal);
    window.location.reload(); // refresh to show empty cart
  };
}
</script>




</html>
