<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="../public/css/allstructure/nav.css">
    <link rel="stylesheet" href="../public/css/searchbox.css">
    <link rel="stylesheet" href="../public/css/card.css">
    <link rel="stylesheet" href="../public/css/shops-product.css">
      <link rel="stylesheet" href="../public/css/selectcontainer.css">
    <title>Anuj's-360</title>
     
    <style>
 button, a {
  -webkit-tap-highlight-color: transparent;  /* blue highlight remove karega */
}
    </style>
</head>
<body>

<!-- Navbar -->
<nav class="navbar">
    <div class="nav-left"><img src="../public/images/logo.jpg" alt="Logo"></div>
    <div class="nav-center"><marquee direction="up" behavior="slide">Services</marquee></div>
    <div class="nav-right">
        <img src="../public/images/nav1.png" alt="Nav Image" id="menuBtn">
        <div class="dropdown" id="dropdownMenu">
            <div class="menu-header">← Back</div>
            <a href="/">Home</a>
            <a href="/aboutus">About</a>
            <a href="/service">Services</a>
         
             <a href="/profile"> My Profile</a>
     
       
        </div>
    </div>
</nav>

<!-- Location  -->
<div class="outer">
    <div class="container">
        <h2>Select</h2>
        <div>
            <select id="districtSelect">
                <option value="">My District</option>
                <option value="hyderabad">Hyderabad</option>
                <option value="rangareddy">Ranga Reddy</option>
            </select>
            <select id="areaSelect">
                <option value="">Select Area</option>
            </select>
        </div>
        <button id="searchBtn">Search</button>

        <div id="locationWrapper">
            <div id="result"></div>
            <div class="search-box-container" style="display:none;">
                <input type="text" id="productSearch" placeholder="Search products...">
            </div>
        </div>
    </div>
</div>

<!-- Categories -->
<div class="producttypes"> 
  
    <button data-category="grocery">Grocery</button>
    <button data-category="fruits">Fruits & Vegetables</button>
    <button data-category="bakery">Bakery</button>
    <button data-category="electronics">Electronics</button>
    <button data-category="garments">Garments</button>
    <button data-category="stationery">Stationery</button>
</div>

<!-- Shops / Products Container -->
<div id="shopsContainer" class="card-container"></div>

<!-- Scripts -->

<!-- Navbar toggle -->
<script>
const menuBtn = document.getElementById("menuBtn");
const dropdownMenu = document.getElementById("dropdownMenu");
const backBtn = document.querySelector(".menu-header");

menuBtn.addEventListener("click",()=>dropdownMenu.classList.toggle("show"));
backBtn.addEventListener("click",()=>dropdownMenu.classList.remove("show"));
</script>

<!-- District & Area dropdown -->
<script>
const districtSelect = document.getElementById("districtSelect");
const areaSelect = document.getElementById("areaSelect");
const resultDiv = document.getElementById("result");

const areas = {
    hyderabad:["Nagole","Tarnaka","Dilsukhnagar","LB Nagar","Uppal","Afzalgunj","Koti","Charminar"],
    rangareddy:["Ibrahimpatnam","B.N. Reddy Nagar","Meerpet","Balapur","Cherlapalli","Ghatkesar"]
};

districtSelect.addEventListener("change", function(){
    const selectedDistrict = this.value;
    areaSelect.innerHTML = '<option value="">Select Area</option>';
    if(selectedDistrict && areas[selectedDistrict]){
        areas[selectedDistrict].forEach(area=>{
            const option = document.createElement("option");
            option.value = area.toLowerCase();
            option.textContent = area;
            areaSelect.appendChild(option);
        });
    }
});
</script>

<!-- Search button -->
<script>
const searchBtn = document.getElementById("searchBtn");
const searchBoxContainer = document.querySelector(".search-box-container");
const shopsContainer = document.getElementById("shopsContainer");
const searchInput = document.getElementById('productSearch');

searchBtn.addEventListener("click", function(e){
     e.preventDefault();
    const district = districtSelect.value;
    const area = areaSelect.value;

    if(!district || !area){
        resultDiv.textContent = "Please select district and area.";
        resultDiv.style.color = "red";
        searchBoxContainer.style.display = "none";
    } else {
        resultDiv.style.display = "none";
        searchBoxContainer.style.display = "block";
        shopsContainer.innerHTML = "";
        searchInput.value = "";
    }
});
</script>

<!-- Category buttons -->
<script>
const categoryButtons = document.querySelectorAll(".producttypes button");

categoryButtons.forEach(button=>{
    button.addEventListener("click", async ()=>{
        const district = districtSelect.value;
        const area = areaSelect.value;
        const category = button.dataset.category;

        if(!district || !area){
            alert("Please select district and area first");
            return;
        }

        // Remove active from all
        categoryButtons.forEach(btn=>btn.classList.remove("active"));
        // Set active
        button.classList.add("active");

        // Clear search input & results
        searchInput.value = "";
        shopsContainer.innerHTML = "";

        const res = await fetch(`/api/shops?district=${district}&area=${area}&category=${category}`);
        const shops = await res.json();

        if(shops.length===0){
            shopsContainer.innerHTML="<p>No shops found</p>";
            return;
        }

        shops.forEach(shop=>{
            const card = document.createElement("div");
            card.classList.add("card");
            card.innerHTML = `
                <img src="${shop.image}" class="card-img">
                <div class="card-content">
                    <h3>${shop.name}</h3>
                    <a href="/shop/${shop._id}"><button>Visit</button></a>
                </div>
            `;
            shopsContainer.appendChild(card);
        });
    });
});
</script>

<!-- Product search -->
<script>
searchInput.addEventListener('input', async ()=>{
    const query = searchInput.value.trim();
    const district = districtSelect.value;
    const area = areaSelect.value;
    shopsContainer.innerHTML = "";

    if(!district || !area){
        if(query) alert("Please select district and area first");
        return;
    }
    if(!query) return;

    try{
        const res = await fetch(`/searchProducts?q=${encodeURIComponent(query)}&district=${district}&area=${area}`);
        const data = await res.json();

        if(data.length===0){
            shopsContainer.innerHTML="<p style='padding:10px'>No products found</p>";
            return;
        }

        data.forEach(item=>{
            item.shops.forEach(shop=>{
                const card = document.createElement("div");
                card.classList.add("card");
                card.innerHTML = `
                    <img src="${item.product.image || '/public/images/default.png'}" class="card-img">
                    <div class="card-content">
                        <h3>${item.product.name}</h3>
                        <p>Price: ₹${item.product.price}</p>
                        <p style="font-size:14px;color:#555;">Shop: ${shop.name} (${shop.district}, ${shop.area})</p>
                        <a href="/shop/${shop._id}"><button>Visit Shop</button></a>
                    </div>
                `;
                shopsContainer.appendChild(card);
            });
        });

      
        categoryButtons.forEach(btn=>btn.classList.remove("active"));

    } catch(err){
        console.error(err);
        shopsContainer.innerHTML="<p style='padding:10px'>Error fetching results</p>";
    }
});
</script>

</body>
</html>