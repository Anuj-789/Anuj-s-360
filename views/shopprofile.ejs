<script>
// Add Product Modal Logic
// Add Product Modal Logic
const addProductsBtn = document.getElementById('addProductsBtn');
const addProductModal = document.getElementById('addProductModal');
const closeAddProduct = document.getElementById('closeAddProduct');
const confirmAddProduct = document.getElementById('confirmAddProduct');

const productImageFile = document.getElementById('productImageFile');
const productImagePreview = document.getElementById('productImagePreview');

// Open modal
addProductsBtn.addEventListener('click', () => {
    addProductModal.style.display = 'flex';
});

// Close modal
closeAddProduct.addEventListener('click', () => {
    addProductModal.style.display = 'none';
    clearModalFields();
});

// Show image preview when user selects a file
productImageFile.addEventListener('change', function() {
    const file = this.files[0];
    if(file){
        const reader = new FileReader();
        reader.onload = function(e){
            productImagePreview.src = e.target.result;
            productImagePreview.style.display = 'block';
        }
        reader.readAsDataURL(file);
    } else {
        productImagePreview.src = '';
        productImagePreview.style.display = 'none';
    }
});

// Confirm add product
confirmAddProduct.addEventListener('click', () => {
    const name = document.getElementById('productName').value.trim();
    const imageFile = productImageFile.files[0];
    const desc = document.getElementById('productDesc').value.trim();
    const price = document.getElementById('productPrice').value.trim();

    if(!name || !imageFile || !desc || !price){
        alert("Please fill all fields and select an image!");
        return;
    }

    alert(`${name} is added in your shop's products!`);

    // Clear modal fields and close
    clearModalFields();
    addProductModal.style.display = 'none';
});

function clearModalFields(){
    document.getElementById('productName').value = '';
    productImageFile.value = '';
    productImagePreview.src = '';
    productImagePreview.style.display = 'none';
    document.getElementById('productDesc').value = '';
    document.getElementById('productPrice').value = '';
}


</script>

