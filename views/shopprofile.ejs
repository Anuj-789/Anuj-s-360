<!-- Delete Confirmation Modal -->
<div id="deleteConfirmModal" style="display:none;">
  <div class="modal-content">
    <p id="deleteMessage"></p>

    <div class="modal-buttons">
      <button id="confirmDeleteBtn" class="confirm-btn">Confirm</button>
      <button id="cancelDeleteBtn" class="cancel-btn">Cancel</button>
    </div>

    <div id="loaderContainer" class="loader-container" style="display:none;">
      <div class="spinner"></div>
    </div>

    <div id="successContainer" class="success-container" style="display:none;">
      <div class="checkmark">
        
      </div>
