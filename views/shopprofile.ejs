    <div class="update-buttons">
      <button id="confirmUpdateBtn" class="update-confirm">Update</button>
      <button id="cancelUpdateBtn" class="update-cancel">Cancel</button>
    </div>

    <!-- Loader -->
    <div id="updateLoader" class="update-loader" style="display:none;">
      <div class="spinner"></div>
    </div>

    <!-- Success -->
    <div id="updateSuccess" class="update-success" style="display:none;">
      <div class="checkmark">
       
      </div>
      <p>Successfully Updated!</p>
    </div>

  </div>
