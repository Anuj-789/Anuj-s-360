<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Product Card</title>
 
  <link rel="stylesheet" href="productbox.css">
  <link rel="stylesheet" href="../public/css/allstructure/nav.css">
  <link rel="stylesheet" href="../public/css/authcss/aside.css">
  <link rel="stylesheet" href="../public/css/authcss/section.css">
  <link rel="stylesheet" href="../public/css/mycart.css">
   <link rel="stylesheet" href="../public/css/cardcssforshopprofile.css">
  <style>
    /* NAVBAR */

    
.navbar{
     border-bottom: 5px solid rgb(16, 12, 133);
}
  
.navbar {
  position: fixed;
   right: 0;  
  top: 0;
  width: 100%;
  height: 200px;
  z-index: 500;
  transition: transform 0.3s ease;
  
}

/* MAIN CONTAINER */
.main-container {
  display: flex;
  margin-top: 220px; /* navbar height */
}

/* LEFT SHOP BOX */
.shop-box {
  width: 20%;
  height: calc(100vh - 220px); /* full sidebar height minus navbar */
  position: fixed;
  top: 200px;
  left: 0;
  background: #fff;
  padding: 20px;
  border-right: 3px solid green;
  box-shadow: 2px 0 10px rgba(0,0,0,0.1);
  border-radius: 15px;
  border-bottom: 5px solid rgb(16, 12, 133);

  display: flex;
  flex-direction: column; /* stack content vertically */
  overflow-y: auto;       /* enable vertical scrolling if content overflows */
}
.shop-box p{
  text-align: left;
}

.shop-img {
  width: 100%;
  height: 200px;
  border-radius: 50%;
  object-fit: cover; /* ensures full image fits nicely */
  margin-bottom: 10px;
}

.shop-name {
  margin: 10px 0 5px;
}

.shop-bottom {
   /* pushes last updated & logout to the bottom */
  text-align: center;
}
.shop-updated {
  font-size: 12px;
  color: #555;
  margin-top: 15px;

  
}
.shop-fav{
  margin-top: 20px;
}

.shop-desc {
  font-size: 14px;
  color: #555;
  margin: 15px;
}
.shop-actions {
  display: flex;
  flex-direction: row;
  margin-top: 15px;
  margin-bottom: 15px;
 justify-content: center; 
 gap: 20%;
}

.shop-cart {
  flex: 1;
  padding: 10px;
  background: rgb(14, 110, 14);
  color: white;
  border: none;
  border-radius: 6px;
  cursor: pointer;
  min-width: max-content;
}

.shop-fav {
  width: 75px;
  font-size: 20px;
  border-radius: 6px;
}
.shop-rating{
    margin: 8px 0px 10px 0px;
}

/* PRODUCT AREA */
.product-area {
  margin-left: 20%;
  width: 80%;
  padding: 20px;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 20px;
}

/* HIDE ON SCROLL */
.hide {
  transform: translateY(-100%);
}

.hide-left {
  transform: translateX(-100%);
}

.auth-buttons button {
  padding: 10px 20px;
  margin-right: 10px;
  background: green;
  color: white;
  border: none;
  border-radius: 6px;
  cursor: pointer;
}

.auth-form {
  margin-top: 30px;
  max-width: 400px;
}

 .chat{
      
        position: fixed;
        bottom: 8%;
        left:92%;
     
     }

     .shop-info-wrapper {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.welcome-btn {
  margin: 20px;
}
.welcome-btn:hover {
   background: #c3edd4; 
   color: #111;  /* darker green */
  transform: scale(1.05); /* slight zoom */
  box-shadow: 0 4px 8px rgba(0,0,0,0.2);
}


  </style>
  <style>
   
  </style>
</head>
<body>



<!-- ===== NAVBAR (YOUR CODE) ===== -->
<nav class="navbar">
    <div class="nav-left">
        <img src="../public/images/logo.jpg" alt="Logo">
    </div>

    <div class="nav-center">
         <% if(shop) { %>
    <marquee direction="up" behavior="slide"><%= shop.name %></marquee>
  <% } else { %>
    <marquee direction="up" behavior="slide">Shop Profile</marquee>
  <% } %>
    </div>

    <div class="nav-right">
        <img src="../public/images/nav1.png" id="menuBtn">

        <div class="dropdown" id="dropdownMenu">
            <div class="menu-header">← Back</div>
            <a href="/">Home</a>
            <a href="/aboutus">About</a>
            <a href="/service">Services</a>
        </div>
    </div>
</nav>

<!-- MAIN LAYOUT -->
<div class="main-container">

 <aside class="shop-box" id="shopBox">
  <% if(shop) { %>
    <div class="shop-info-wrapper">
      <!-- Shop Image -->
      <img src="<%= shop.image %>" class="shop-img" alt="Shop Image">

      <!-- Shop Details -->
      <h3 class="shop-name"><%= shop.name %></h3>
      <p><strong>Shopkeeper:</strong> <%= shop.shopkeeperName %></p>
      <p><strong>Category:</strong> <%= shop.category %></p>
      <p><strong>District:</strong> <%= shop.district %></p>
      <p><strong>Area:</strong> <%= shop.area %></p>
      <p><strong>Address:</strong> <%= shop.address %></p>
      <p><strong>Contact:</strong> <%= shop.contactNumber %></p>
      <p><strong>WhatsApp:</strong> <%= shop.whatsappNumber %></p>
      <p><strong>Email:</strong> <%= shop.email %></p>

      <!-- Shop Actions -->
      <div class="shop-actions">
        <a href="<%= shop.locationLink %>" target="_blank">
          <button class="shop-cart">Location</button>
        </a>
        <a >
          <button class="shop-cart">Update </button>
        </a>
      </div>

      



   

      <!-- Last Updated & Logout -->
      <div class="shop-bottom">
        <p class="shop-updated">Last Updated: <%= shop.updatedAt ? shop.updatedAt.toLocaleString() : 'N/A' %></p>
        <form action="/shops/logout" method="GET">
          <button type="submit" class="shop-fav">Logout</button>
        </form>
      </div>
    </div>
  <% } else { %>
    <img src="../public/images/profilegif.webp" class="shop-img" alt="profile">
    <h3 class="shop-name">Name</h3>
    <p>Please Signin first</p>
  <% } %>
</aside>


<section class="product-area">

  <% if(shop) { %>
    <!-- Welcome message + action buttons -->
    <div class="welcome-message">
      <h2>Welcome, <%= shop.shopkeeperName %>!</h2><br>

      <button class="welcome-btn" id="viewProductsBtn">View Products</button>

      <button class="welcome-btn" id="addProductsBtn">Add Product</button>
      <button class="welcome-btn" id="viewtotalorders">View Orders</button>
    </div>

<div id="productsContainer" style="margin-top:20px;"> <!-- display:none remove kiya -->
  <% if (productsByCategory && Object.keys(productsByCategory).length > 0) { %>
    <% Object.keys(productsByCategory).forEach(category => { %>
      <h3 style="text-transform: capitalize; margin-top: 20px; color: #111; border-bottom: 2px solid #ddd; padding-bottom: 5px;">
        <%= category %>
      </h3>

      <div class="product-grid">
        <% productsByCategory[category].forEach(product => { %>
          <div class="product-card">
            <img src="<%= product.image %>" alt="<%= product.name %>" style="width:100%; height:180px; object-fit:cover; border-radius:8px;">
            <h3><%= product.name %></h3>
            <p><%= product.description || "Best product" %></p>
            <p>₹<%= product.price %></p>
           
          </div>
        <% }) %>
      </div>
    <% }) %>
  <% } else { %>
    <p style="margin-top:20px; font-size:16px; color:red;">No products available</p>
  <% } %>
</div>



  <% } else { %>
    <!-- Login form shows only if shop is not logged in -->
    <div id="loginForm" class="auth-form-wrapper">
      <div class="auth-form-image">
        <img src="../public/images/shoplogin.gif" height="200px" alt="Login Illustration">
      </div>
      <div class="auth-form">
        <h2>Login</h2>
        <p style="color: rgb(249, 0, 91); font-weight: bold; display: none;" id="loginError"></p>
        <form action="/shops/login" method="POST" id="loginFormSubmit">
          <input type="email" name="email" placeholder="Email" required><br>
          <input type="password" name="password" placeholder="Password" required><br>
          <button type="submit">Login</button>
        </form>
      </div>
    </div>
  <% } %>

</section>






<script>
document
  .getElementById("loginFormSubmit") // make sure this is the shop login form ID
  .addEventListener("submit", async function (e) {

    e.preventDefault(); // stop page reload

    const formData = new FormData(this);
    const data = Object.fromEntries(formData);

    try {
      const res = await fetch("/shops/login", {  // ✅ post to shop login
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data)
      });

      const result = await res.json();

      if (!res.ok) {
        alert(result.message);  // show backend error
        return;
      }

      // ✅ success
      alert("Shop login successful");
      window.location.href = "/shopprofile"; // ✅ redirect to shop profile

    } catch (err) {
      alert("Something went wrong");
      console.error(err);
    }
});
</script>


<script>
let lastScroll = 0;
const navbar = document.getElementById("navbar");
const shopBox = document.getElementById("shopBox");

window.addEventListener("scroll", () => {
  let currentScroll = window.pageYOffset;

  if (currentScroll > lastScroll) {
    // scrolling down
    navbar.classList.add("hide");
    shopBox.classList.add("hide-left");
  } else {
    // scrolling up
    navbar.classList.remove("hide");
    shopBox.classList.remove("hide-left");
  }

  lastScroll = currentScroll;
});
</script>



<script>
    const menuBtn = document.getElementById("menuBtn");
    const dropdownMenu = document.getElementById("dropdownMenu");
    const backBtn = document.querySelector(".menu-header");

    menuBtn.addEventListener("click", () => {
        dropdownMenu.classList.toggle("show");
    });

    backBtn.addEventListener("click", () => {
        dropdownMenu.classList.remove("show");
    });
</script>





<script>
  // Toggle products on button click
  const viewBtn = document.getElementById('viewProductsBtn');
  const productsContainer = document.getElementById('productsContainer');

  viewBtn.addEventListener('click', () => {
    if(productsContainer.style.display === 'none' || productsContainer.style.display === '') {
      productsContainer.style.display = 'block';
      viewBtn.textContent = 'Hide Products';
    } else {
      productsContainer.style.display = 'none';
      viewBtn.textContent = 'View Products';
    }
  });
</script>


<!-- Add Product Modal -->
<div id="addProductModal" style="
    display:none;
    position:fixed; top:0; left:0; width:100%; height:100%;
    background: rgba(119, 109, 192, 0.6);
    justify-content:center; align-items:center;
    z-index:2000;
">
    <div style="
           background: linear-gradient(90deg, #e9fcd4, #bfdcff);
        padding:20px;
        border-radius:12px;
        width:350px;
        text-align:left;
        position:relative;
    ">
        <h2>Add Product</h2>

        <label>Product Name:</label>
        <input type="text" id="productName" style="width:100%; margin-bottom:10px; padding:6px;"/>

        <label>Product Image:</label>
        <input type="file" id="productImageFile" accept="image/*" style="width:100%; margin-bottom:10px;"/>
        <img id="productImagePreview" src="" alt="Preview" style="width:100%; height:150px; object-fit:cover; margin-bottom:10px; display:none; border-radius:6px; border:1px solid #ccc;" />

        <label>Description:</label>
        <textarea id="productDesc" style="width:100%; margin-bottom:10px; padding:6px;"></textarea>

        <label>Price:</label>
        <input type="number" id="productPrice" style="width:100%; margin-bottom:15px; padding:6px;" />

        <button id="confirmAddProduct" style="width:100%; padding:10px; background:green; color:white; border:none; border-radius:6px; margin-bottom:5px;">
            Add Product
        </button>

        <button id="closeAddProduct" style="width:100%; padding:10px; background:red; color:white; border:none; border-radius:6px;">
            Cancel
        </button>
    </div>
</div>



</body>
<script>
// Add Product Modal Logic
// Add Product Modal Logic
const addProductsBtn = document.getElementById('addProductsBtn');
const addProductModal = document.getElementById('addProductModal');
const closeAddProduct = document.getElementById('closeAddProduct');
const confirmAddProduct = document.getElementById('confirmAddProduct');

const productImageFile = document.getElementById('productImageFile');
const productImagePreview = document.getElementById('productImagePreview');

// Open modal
addProductsBtn.addEventListener('click', () => {
    addProductModal.style.display = 'flex';
});

// Close modal
closeAddProduct.addEventListener('click', () => {
    addProductModal.style.display = 'none';
    clearModalFields();
});

// Show image preview when user selects a file
productImageFile.addEventListener('change', function() {
    const file = this.files[0];
    if(file){
        const reader = new FileReader();
        reader.onload = function(e){
            productImagePreview.src = e.target.result;
            productImagePreview.style.display = 'block';
        }
        reader.readAsDataURL(file);
    } else {
        productImagePreview.src = '';
        productImagePreview.style.display = 'none';
    }
});

// Confirm add product
confirmAddProduct.addEventListener('click', () => {
    const name = document.getElementById('productName').value.trim();
    const imageFile = productImageFile.files[0];
    const desc = document.getElementById('productDesc').value.trim();
    const price = document.getElementById('productPrice').value.trim();

    if(!name || !imageFile || !desc || !price){
        alert("Please fill all fields and select an image!");
        return;
    }

    alert(`${name} is added in your shop's products!`);

    // Clear modal fields and close
    clearModalFields();
    addProductModal.style.display = 'none';
});

function clearModalFields(){
    document.getElementById('productName').value = '';
    productImageFile.value = '';
    productImagePreview.src = '';
    productImagePreview.style.display = 'none';
    document.getElementById('productDesc').value = '';
    document.getElementById('productPrice').value = '';
}


</script>

</html>
