<body>



<!-- ===== NAVBAR (YOUR CODE) ===== -->
<nav class="navbar">
    <div class="nav-left">
        <img src="../public/images/logo.jpg" alt="Logo">
    </div>

    <div class="nav-center">
         <% if(shop) { %>
    <marquee direction="up" behavior="slide" class="shopnam"><%= shop.name %></marquee>
      <marquee direction="up" behavior="slide" ><img src="<%= shop.image %>" class="shop-img" alt="Shop Image"></marquee>

  <% } else { %>
    <marquee direction="up" behavior="slide">Shop Profile</marquee>
  <% } %>
    </div>

    <div class="nav-right">
        <img src="../public/images/nav1.png" id="menuBtn">

        <div class="dropdown" id="dropdownMenu">
            <div class="menu-header">← Back</div>
            <a href="/">Home</a>
            <a href="/aboutus">About</a>
            <a href="/service">Services</a>
             <a href="/profile"> user Profile</a>
     
       
        </div>
    </div>
</nav>

<!-- MAIN LAYOUT -->
<div class="main-container">

 <aside class="shop-box" id="shopBox" >
  <% if(shop) { %>
    <div class="shop-info-wrapper">
      <!-- Shop Image -->
      <img src="<%= shop.image %>" class="shop-img" alt="Shop Image">

      <!-- Shop Details -->
      <h3 class="shop-name"><%= shop.name %></h3>
      <p><strong>Shopkeeper:</strong> <%= shop.shopkeeperName %></p>
      <p><strong>Category:</strong> <%= shop.category %></p>
      <p><strong>District:</strong> <%= shop.district %></p>
      <p><strong>Area:</strong> <%= shop.area %></p>
      <p><strong>Address:</strong> <%= shop.address %></p>
      <p><strong>Contact:</strong> <%= shop.contactNumber %></p>
      <p><strong>WhatsApp:</strong> <%= shop.whatsappNumber %></p>
      <p><strong>Email:</strong> <%= shop.email %></p>
       <p  class="shop-updated">Last Updated: <%= shop.updatedAt ? shop.updatedAt.toLocaleString() : 'N/A' %></p>

      <!-- Shop Actions -->
      <div class="shop-actions">
        <a href="<%= shop.locationLink %>" target="_blank">
          <button class="shop-cart">Location</button>
        </a>
        <a >
       <button class="shop-cart" id="openUpdateShopModal">Profile Update</button>
        </a>
           <form action="/shops/logout" method="GET">
          <button type="submit" class="shop-fav">Logout</button>
        </form>
      </div>
      <!-- Last Updated & Logout -->
     
    </div>
  <% } else { %>
    <img src="../public/images/profilegif.webp" class="shop-img" id="beforeloginuserimage" alt="profile">
    <h3 class="shop-name">Name</h3>
    <p>Please Signin first</p>
  <% } %>
</aside>


<section class="product-area">

  <% if(shop) { %>
    <!-- Welcome message + action buttons -->
    <div class="welcome-message">
      <h2>Welcome, <%= shop.shopkeeperName %>!</h2><br>

      <button class="welcome-btn" id="viewProductsBtn">View Products</button>

      <button class="welcome-btn" id="addProductsBtn">Add Product</button>
      <button class="welcome-btn" id="viewtotalorders">View Orders</button>
    </div>

<div id="productsContainer" style="margin-top:20px;"> <!-- display:none remove kiya -->
  <% if (productsByCategory && Object.keys(productsByCategory).length > 0) { %>
    <% Object.keys(productsByCategory).forEach(category => { %>
      <h3 style="text-transform: capitalize; margin-top: 20px; color: #111; border-bottom: 2px solid #ddd; padding-bottom: 5px;">
        <%= category %>
      </h3>

      <div class="product-grid">
        <% productsByCategory[category].forEach(product => { %>
          <div class="product-card">
            <img src="<%= product.image %>" alt="<%= product.name %>" style="width:100%; height:180px; object-fit:cover; border-radius:8px;">
            <h3><%= product.name %></h3>
            <p><%= product.description || "Best product" %></p>
            <p>₹<%= product.price %></p>
            <!-- Buttons -->
  <div class="product-actions">
      <button class="update-product-btn" data-id="<%= product._id %>">Update</button>
      <button class="delete-product-btn" data-id="<%= product._id %>">Delete</button>
  </div>


           
          </div>
        <% }) %>
      </div>
    <% }) %>
  <% } else { %>
    <p style="margin-top:20px; font-size:16px; color:red;">No products available</p>
  <% } %>
</div>



  <% } else { %>
    <!-- Login form shows only if shop is not logged in -->
    <div id="loginForm" class="auth-form-wrapper">
      <div class="auth-form-image">
        <img src="../public/images/shoplogin.gif" height="200px" alt="Login Illustration">
      </div>
      <div class="auth-form">
        <h2>Login</h2>
        <p style="color: rgb(249, 0, 91); font-weight: bold; display: none;" id="loginError"></p>
        <form action="/shops/login" method="POST" id="loginFormSubmit">
          <input type="email" name="email" placeholder="Email" required><br>
          <input type="password" name="password" placeholder="Password" required><br>
          <button type="submit">Login</button>
        </form>
      </div>
    </div>
  <% } %>

</section>



<!-- Profile Update Modal -->
<% if(shop) { %>
<div id="updateShopModal" style="
    display:none;
    position:fixed;
    top:0;
    left:0;
    width:100%;
    height:100%;
    background: rgba(0,0,0,0.6);
    justify-content:center;
    align-items:center;
    z-index:2000;
">
  <div style="
        background:#fff;
        padding:20px;
        border-radius:12px;
        width:90%;
        max-width:400px;
        text-align:left;
        position:relative;
        max-height:90vh;
        overflow-y:auto;
  ">
    <h2 style="text-align:center; margin-bottom:15px;">Update Shop Profile</h2>
    <form id="updateShopForm">
      <label>Shop Name:</label>
      <input type="text" name="name" value="<%= shop.name %>" style="width:100%; margin-bottom:10px; padding:6px;">

      <label>Shopkeeper Name:</label>
      <input type="text" name="shopkeeperName" value="<%= shop.shopkeeperName %>" style="width:100%; margin-bottom:10px; padding:6px;">

      <label>Email:</label>
      <input type="email" name="email" value="<%= shop.email %>" style="width:100%; margin-bottom:10px; padding:6px;">

      <label>Contact Number:</label>
      <input type="text" name="contactNumber" value="<%= shop.contactNumber %>" style="width:100%; margin-bottom:10px; padding:6px;">

      <label>WhatsApp Number:</label>
      <input type="text" name="whatsappNumber" value="<%= shop.whatsappNumber %>" style="width:100%; margin-bottom:10px; padding:6px;">

      <label>District:</label>
      <input type="text" name="district" value="<%= shop.district %>" style="width:100%; margin-bottom:10px; padding:6px;">

      <label>Area:</label>
      <input type="text" name="area" value="<%= shop.area %>" style="width:100%; margin-bottom:10px; padding:6px;">

      <label>Address:</label>
      <input type="text" name="address" value="<%= shop.address %>" style="width:100%; margin-bottom:10px; padding:6px;">

      <label>Category:</label>
      <input type="text" name="category" value="<%= shop.category %>" style="width:100%; margin-bottom:10px; padding:6px;">

      <label>Location Link:</label>
      <input type="text" name="locationLink" value="<%= shop.locationLink %>" style="width:100%; margin-bottom:15px; padding:6px;">

      <div style="display:flex; gap:10px;">
        <button type="button" id="updateShopBtn" style="flex:1; padding:10px; background:green; color:white; border:none; border-radius:6px;">
          Update
        </button>
        <button type="button" id="closeUpdateShopModal" style="flex:1; padding:10px; background:red; color:white; border:none; border-radius:6px;">
          Cancel
        </button>
      </div>
    </form>
  </div>
</div>
<script>
const updateShopModal = document.getElementById('updateShopModal');
const openUpdateBtn = document.getElementById('openUpdateShopModal');
const closeUpdateBtn = document.getElementById('closeUpdateShopModal');
const updateForm = document.getElementById('updateShopForm');

// Open modal
openUpdateBtn.addEventListener('click', () => {
    updateShopModal.style.display = 'flex';
    updateShopModal.style.position = 'fixed';
    updateShopModal.style.top = '0';
    updateShopModal.style.left = '0';
    updateShopModal.style.width = '100%';
    updateShopModal.style.height = '100%';
    updateShopModal.style.justifyContent = 'center';
    updateShopModal.style.alignItems = 'center';
    updateShopModal.style.background = 'rgba(0,0,0,0.4)';
    updateShopModal.style.zIndex = '2000';
});

// Close modal
closeUpdateBtn.addEventListener('click', () => {
    updateShopModal.style.display = 'none';
});

// Submit update via AJAX
document.getElementById('updateShopBtn').addEventListener('click', async () => {
    const formData = new FormData(updateForm);
    const data = Object.fromEntries(formData);

    try {
        const res = await fetch('/shop/update', {   // ✅ correct route
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });

        const result = await res.json();

        if (res.ok) {
            alert(result.message);  // Shop profile updated successfully
            updateShopModal.style.display = 'none';
            window.location.reload(); // show updated data immediately
        } else {
            alert(result.message || 'Something went wrong!');
        }

    } catch(err) {
        console.error(err);
        alert('Something went wrong!');
    }
});
</script>

<style>
  /* Responsive Input Fields */
  #updateShopForm input, #updateShopForm textarea {
    width:100%;
    box-sizing:border-box;
  }

  #updateShopForm label {
    font-weight:bold;
    margin-top:8px;
    display:block;
  }

  @media screen and (max-width:500px){
    #updateShopModal div {
      width:95%;
      padding:15px;
    }
    #updateShopForm button {
      font-size:14px;
      padding:8px;
    }
  }
</style>
<% } %>


<script>
document
  .getElementById("loginFormSubmit") // make sure this is the shop login form ID
  .addEventListener("submit", async function (e) {

    e.preventDefault(); // stop page reload

    const formData = new FormData(this);
    const data = Object.fromEntries(formData);

    try {
      const res = await fetch("/shops/login", {  // ✅ post to shop login
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data)
      });

      const result = await res.json();

      if (!res.ok) {
        alert(result.message);  // show backend error
        return;
      }

      // ✅ success
      alert("Shop login successful");
      window.location.href = "/shopprofile"; // ✅ redirect to shop profile

    } catch (err) {
      alert("Something went wrong");
      console.error(err);
    }
});
</script>


<script>
let lastScroll = 0;
const navbar = document.getElementById("navbar");
const shopBox = document.getElementById("shopBox");

window.addEventListener("scroll", () => {
  let currentScroll = window.pageYOffset;

  if (currentScroll > lastScroll) {
    // scrolling down
    navbar.classList.add("hide");
    shopBox.classList.add("hide-left");
  } else {
    // scrolling up
    navbar.classList.remove("hide");
    shopBox.classList.remove("hide-left");
  }

  lastScroll = currentScroll;
});
</script>



