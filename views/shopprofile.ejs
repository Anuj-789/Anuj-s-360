<script>
  const updateModal = document.getElementById('updateProductModal');
const updateName = document.getElementById('updateName');
const updateDesc = document.getElementById('updateDesc');
const updatePrice = document.getElementById('updatePrice');
const confirmUpdateBtn = document.getElementById('confirmUpdateBtn');
const cancelUpdateBtn = document.getElementById('cancelUpdateBtn');
const updateLoader = document.getElementById('updateLoader');
const updateSuccess = document.getElementById('updateSuccess');

let currentCard = null;

// Open update modal
document.querySelectorAll('.update-product-btn').forEach(btn => {
  btn.addEventListener('click', () => {

    currentCard = btn.closest('.product-card');

    // Prefill existing data
    updateName.value = currentCard.querySelector('h3').innerText;
    updateDesc.value = currentCard.querySelector('p').innerText;
    updatePrice.value = currentCard.querySelectorAll('p')[1].innerText.replace("₹","");

    updateLoader.style.display = 'none';
    updateSuccess.style.display = 'none';

    updateModal.style.display = 'flex';
  });
});

// Cancel
cancelUpdateBtn.addEventListener('click', () => {
  updateModal.style.display = 'none';
});

// Confirm update (Demo UI)
confirmUpdateBtn.addEventListener('click', async () => {

  confirmUpdateBtn.disabled = true;
  updateLoader.style.display = 'block';

  await new Promise(res => setTimeout(res, 1500));

  updateLoader.style.display = 'none';
  updateSuccess.style.display = 'flex';

  // Update card UI (frontend only)
  currentCard.querySelector('h3').innerText = updateName.value;
  currentCard.querySelector('p').innerText = updateDesc.value;
  currentCard.querySelectorAll('p')[1].innerText = "₹" + updatePrice.value;

  setTimeout(() => {
    updateModal.style.display = 'none';
    confirmUpdateBtn.disabled = false;
  }, 1200);
});
</script>


